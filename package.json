{
  "name": "poker-chip-counter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "concurrently -n server,client \"tsx watch src/server/main.ts\" \"vite\"",
    "build": "vite build && esbuild src/server/main.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server.mjs",
    "start": "node dist/server.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "test:realtime": "vitest run --project realtime --passWithNoTests",
    "smoke": "node scripts/smoke.mjs",
    "drift": "node scripts/drift.mjs",
    "logs:report": "node scripts/logs-report.mjs",
    "test:e2e:smoke": "playwright test tests/e2e",
    "validate": "pnpm build && pnpm typecheck && pnpm lint && pnpm test:unit && pnpm test:integration && pnpm test:realtime && pnpm smoke && pnpm test:e2e:smoke && pnpm drift"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "effect": "^3.21.4",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.53.0",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.29.0",
    "happy-dom": "^20.10.6",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}
